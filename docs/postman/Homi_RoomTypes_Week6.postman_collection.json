{
  "info": {
    "name": "Homi Backend - Room Types Data (Week 6)",
    "description": "BE4 - Tuần 6: Postman collection kiểm thử dữ liệu module Room Types (giá, số lượng, validation, ảnh, soft-delete vs hidden).\n\nPhân quyền admin/staff/customer đã test ở tuần 5 (AdminRoomTypeAccessTest) — collection này tập trung vào DỮ LIỆU.\n\nChạy theo thứ tự: Auth → Create Hotel (chuẩn bị) → Room Types CRUD → Price/Inventory → Images → Soft Delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:8000/api/v1" },
    { "key": "admin_token", "value": "" },
    { "key": "hotel_id",    "value": "" },
    { "key": "room_type_id","value": "" },
    { "key": "image_id",    "value": "" }
  ],
  "item": [

    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Login as Admin",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('admin_token', pm.response.json().data.token);"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"admin@homi.vn\", \"password\": \"password\" }",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Tạo Hotel dùng cho test",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('hotel_id', pm.response.json().data.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Homi Test Hotel W6\",\n  \"address\": \"123 Test Street\",\n  \"city\": \"Đà Nẵng\",\n  \"star_rating\": 4\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },

    {
      "name": "1. Room Types CRUD",
      "item": [

        {
          "name": "TC-RTD-001 Tạo loại phòng hợp lệ",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
              "const d = pm.response.json().data;",
              "pm.test('name đúng', () => pm.expect(d.name).to.eql('Phòng Deluxe View Biển'));",
              "pm.test('status = active', () => pm.expect(d.status).to.eql('active'));",
              "pm.test('total_rooms đúng', () => pm.expect(d.total_rooms).to.eql(8));",
              "pm.collectionVariables.set('room_type_id', d.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phòng Deluxe View Biển\",\n  \"description\": \"Phòng rộng rãi, view biển.\",\n  \"price_per_night\": 1200000,\n  \"capacity\": 2,\n  \"bed_type\": \"1 giường đôi lớn\",\n  \"area\": 32,\n  \"total_rooms\": 8\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-010 Thiếu name → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));",
              "pm.test('Có lỗi name', () => pm.expect(pm.response.json().errors).to.have.property('name'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price_per_night\": 500000,\n  \"capacity\": 2,\n  \"total_rooms\": 5\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-011 Giá âm → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));",
              "pm.test('Lỗi price_per_night', () => pm.expect(pm.response.json().errors).to.have.property('price_per_night'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phòng Giá Âm\",\n  \"price_per_night\": -100000,\n  \"capacity\": 2,\n  \"total_rooms\": 5\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-013 capacity = 0 → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));",
              "pm.test('Lỗi capacity', () => pm.expect(pm.response.json().errors).to.have.property('capacity'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phòng Sức Chứa 0\",\n  \"price_per_night\": 500000,\n  \"capacity\": 0,\n  \"total_rooms\": 5\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-015 total_rooms = 0 → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));",
              "pm.test('Lỗi total_rooms', () => pm.expect(pm.response.json().errors).to.have.property('total_rooms'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phòng 0 Số Lượng\",\n  \"price_per_night\": 500000,\n  \"capacity\": 2,\n  \"total_rooms\": 0\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-080 Danh sách loại phòng theo hotel",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('data là array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
              "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },

        {
          "name": "TC-RTD-050 Cập nhật một phần (PUT)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('capacity đã đổi', () => pm.expect(pm.response.json().data.capacity).to.eql(4));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"capacity\": 4 }",
              "options": { "raw": { "language": "json" } }
            }
          }
        }

      ]
    },

    {
      "name": "2. Price & Inventory",
      "item": [

        {
          "name": "TC-RTD-030 Cập nhật giá hợp lệ",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Giá đã cập nhật', () => pm.expect(parseFloat(pm.response.json().data.price_per_night)).to.eql(950000));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/price",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"price_per_night\": 950000 }",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-032 Giá âm → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/price",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"price_per_night\": -1 }",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-040 Cập nhật số lượng phòng",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('total_rooms đã đổi', () => pm.expect(pm.response.json().data.total_rooms).to.eql(15));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/inventory",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"total_rooms\": 15 }",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-041 Số lượng = 0 → 422",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 422', () => pm.response.to.have.status(422));"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/inventory",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"total_rooms\": 0 }",
              "options": { "raw": { "language": "json" } }
            }
          }
        }

      ]
    },

    {
      "name": "3. Images",
      "item": [

        {
          "name": "TC-RTD-090 Tạo loại phòng kèm ảnh (path)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const d = pm.response.json().data;",
              "if (d.images && d.images.length) { pm.collectionVariables.set('image_id', d.images[0].id); }"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/hotels/{{hotel_id}}/room-types",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phòng Có Ảnh\",\n  \"price_per_night\": 700000,\n  \"capacity\": 2,\n  \"total_rooms\": 4,\n  \"images\": [\"room-types/img1.jpg\", \"room-types/img2.jpg\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },

        {
          "name": "TC-RTD-094 Xóa ảnh không tồn tại → 404",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ]}
          }],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/images/999999",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }

      ]
    },

    {
      "name": "4. Soft Delete & Restore",
      "item": [

        {
          "name": "TC-RTD-060 Xóa loại phòng không có booking",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]}
          }],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },

        {
          "name": "TC-RTD-070 Khôi phục loại phòng",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/room-types/{{room_type_id}}/restore",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },

        {
          "name": "TC-RTD-071 Khôi phục ID không tồn tại → 404",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/room-types/999999/restore",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }

      ]
    }

  ]
}