	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"health"
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('success = true', () => pm.expect(pm.response.json().success).to.eql(true));",
									"pm.test('database = ok', () => pm.expect(pm.response.json().data.database).to.eql('ok'));"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
